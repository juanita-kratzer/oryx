# Next.js loads .env.local (overrides .env). Use .env.local for local dev.

# Public app URL (for pass barcode/QR, links, mobile API). No trailing slash.
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# App name (watermark text: "Powered by [AppName]")
NEXT_PUBLIC_APP_NAME=Oryx - Apple Wallet Cards

# Firebase Admin — JSON service account string (same Firebase project as the mobile app)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Optional override if not in the service account JSON:
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Admin: comma-separated emails that can access /admin
ADMIN_EMAILS=admin@example.com

# PassKit (Apple Wallet) — see README for how to obtain and encode certs
PASSKIT_CERT_BASE64=
PASSKIT_KEY_BASE64=
PASSKIT_KEY_PASSWORD=
PASSKIT_WWDR_BASE64=
PASSKIT_PASS_TYPE_ID=pass.com.kratzerandco.oryxcards
PASSKIT_TEAM_ID=XXXXXXXXXX
PASSKIT_ORG_NAME=Your Company Name

# NFC tap (Apple VAS) — optional; enables tap-to-open on iPhone
NFC_PUBLIC_KEY=

# SendGrid — email verification codes + exchange notifications
SENDGRID_API_KEY=SG.xxxx
SENDGRID_SENDER_EMAIL=contact@kratzerco.app
SENDGRID_REPLY_TO=contact@kratzerco.app
SENDGRID_SENDER_NAME=Oryx

# Stripe (optional — billing not wired in mobile build phase)
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx

# Cron (optional – for cleanup job)
# CRON_SECRET=random-secret-for-cron-calls
