# Firebase Google Sign-In (after enabling Google in Firebase Console → Authentication)
# From GoogleService-Info.plist: CLIENT_ID and REVERSED_CLIENT_ID
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=39779450467-xxxxxxxx.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_REVERSED_CLIENT_ID=com.googleusercontent.apps.39779450467-xxxxxxxx
# Web client ID from Firebase Console → Authentication → Google → Web SDK configuration
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=39779450467-xxxxxxxx.apps.googleusercontent.com

# Apple Team ID for automatic code signing (Xcode → Signing & Capabilities)
APPLE_TEAM_ID=

# RevenueCat (https://app.revenuecat.com → Project → API Keys)
EXPO_PUBLIC_REVENUECAT_API_KEY=

# App URL (for pass download, NFC links, and sign-up email verification API)
# Production / TestFlight / device builds:
EXPO_PUBLIC_APP_URL=https://oryx-apple-wallet-cards.vercel.app
# Local dev on a physical iPhone (same Wi‑Fi as your Mac): use your Mac LAN IP, not localhost
# EXPO_PUBLIC_APP_URL=http://192.168.1.119:3000
# Simulator only:
# EXPO_PUBLIC_APP_URL=http://localhost:3000
