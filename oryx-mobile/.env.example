# Copy to .env and fill in your values

# Apple Team ID for automatic code signing (Xcode → Signing & Capabilities)
APPLE_TEAM_ID=

# RevenueCat (https://app.revenuecat.com → Project → API Keys)
EXPO_PUBLIC_REVENUECAT_API_KEY=

# App URL (for pass download, NFC links, and sign-up email verification API)
# Local dev: use your Mac IP so web preview can reach the API, e.g. http://192.168.1.117:3000
EXPO_PUBLIC_APP_URL=https://oryx.app
