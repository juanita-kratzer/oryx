rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId}/cards/{cardId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/scannedContacts/{contactId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /publicCards/{cardId} {
      allow read: if true;
      allow write: if request.auth != null && request.resource.data.ownerUserId == request.auth.uid;
    }

    match /exchangeRequests/{requestId} {
      allow create: if true;
      allow read, update: if request.auth != null && resource.data.ownerUserId == request.auth.uid;
    }
  }
}
